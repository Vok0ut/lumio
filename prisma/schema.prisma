generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Plan {
  FREE
  PREMIUM
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  plan      Plan     @default(FREE)
  totalXp   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts         Account[]
  sessions         Session[]
  habits           Habit[]
  tasks            Task[]
  goals            Goal[]
  journals         JournalEntry[]
  events           CalendarEvent[]
  xpLogs           XpLog[]
  nutritionProfile NutritionProfile?
  foodEntries      FoodEntry[]
  mealTemplates    MealTemplate[]
  weightLogs       WeightLog[]
}

model DevCode {
  id        String   @id @default(cuid())
  code      String   @unique
  usedBy    String?  // email del usuario que lo canjeó
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Habit {
  id        String   @id @default(cuid())
  userId    String
  name      String
  target    String
  category  String
  createdAt DateTime @default(now())

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs HabitLog[]
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  date      DateTime
  completed Boolean

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
}

model Task {
  id        String     @id @default(cuid())
  userId    String
  title     String
  priority  String
  tags      String[]
  estimate  String?
  status    TaskStatus @default(TODO)
  createdAt DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model Goal {
  id         String      @id @default(cuid())
  userId     String
  title      String
  deadline   DateTime
  category   String
  progress   Int         @default(0)
  createdAt  DateTime    @default(now())

  milestones Milestone[]
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Milestone {
  id     String  @id @default(cuid())
  goalId String
  label  String
  done   Boolean @default(false)
  order  Int

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @default(now())
  title     String
  body      String
  mood      Int
  tags      String[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CalendarEvent {
  id     String   @id @default(cuid())
  userId String
  date   DateTime
  time   String
  title  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model XpLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  xp        Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── LumioNutrition ───

enum NutritionGoal {
  MUSCLE_GAIN
  MAINTENANCE
  FAT_LOSS
}

model NutritionProfile {
  id            String        @id @default(cuid())
  userId        String        @unique
  weight        Float         // kg
  height        Float         // cm
  age           Int
  goal          NutritionGoal
  activityLevel Float         @default(1.55) // PAL factor
  bmr           Float         // kcal — cached Mifflin-St Jeor
  tdee          Float         // kcal — BMR * activityLevel
  targetKcal    Float         // kcal — adjusted by goal
  targetProtein Float         // g
  targetCarbs   Float         // g
  targetFat     Float         // g
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FoodEntry {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime // date only (T00:00:00Z)
  meal      String   // "desayuno" | "almuerzo" | "cena" | "snack"
  name      String
  grams     Float
  kcal      Float
  protein   Float    @default(0)
  carbs     Float    @default(0)
  fat       Float    @default(0)
  photoUrl  String?  // base64 data URL or null
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model MealTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  meal      String
  foods     String   // JSON stringified array of { name, grams, kcal, protein, carbs, fat }
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WeightLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  weight    Float    // kg
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}
