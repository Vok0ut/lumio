# Base de datos (PostgreSQL — Supabase, Railway, Neon, etc.)
DATABASE_URL="postgresql://user:password@localhost:5432/lumio"

# NextAuth
NEXTAUTH_SECRET="genera-un-string-aleatorio-de-64-caracteres-minimo-aqui"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (console.cloud.google.com → Credentials)
GOOGLE_CLIENT_ID="tu-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="tu-client-secret"

# Email — opcion A: Gmail SMTP (mas facil para pocos usuarios)
GMAIL_USER="tu-correo@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# Email — opcion B: Resend (resend.com, requiere dominio verificado)
RESEND_API_KEY="re_tu_api_key"

# Redis (Upstash — upstash.com)
UPSTASH_REDIS_REST_URL="https://tu-instancia.upstash.io"
UPSTASH_REDIS_REST_TOKEN="tu-token"

# Entorno
NODE_ENV="development"
