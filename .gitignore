# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code local settings (may contain sensitive env refs)
.claude/settings.local.json

# Android / Bubblewrap (keep locally, don't affect Vercel)
/app/
/gradle/
/gradlew
/gradlew.bat
/build.gradle
/settings.gradle
/twa-manifest.json
/manifest-checksum.txt
/store_icon.png
/android.keystore
